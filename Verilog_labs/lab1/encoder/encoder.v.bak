module encoder (input [7:0]data_in ,output wire [2:0]data_out);
reg x;
nand (x,data_in[7],data_in[6],data_in[5],data_in[4]);
always @(*) begin
    
if(~x)
begin
decoder_4to_2 d1(.data_in(data_in[3:0]),.data_out(data_out[1:0]));
assign data_out[2]=x;
end
else
begin
decoder_4to_2 d2(.data_in(data_in[7:4]),.data_out(data_out[1:0]));
assign data_out[2]=x;
end
end
endmodule
