module alu_tb();
    
   
   reg [3:0]a,b;
   reg [3:0]command;
   wire [3:0]out;
	
  integer i,j,k;
reg [7:0]l;
reg [3:0]m;
   reg [79:0]string_cmd;
parameter BUFF =4'b0000,
          NOR_L=4'b0001,
          NOR_B=4'b0010,
          NAND_L=4'b0011,
          NAND_B=4'b0100,
          OR_L=4'b0101,
          OR_B=4'b0110,
          AND_L=4'b0111,
          AND_B=4'b1000;


   
   alu a1 (
          .a(a[3:0]),
          .b(b[3:0]),
          .command(command),
	   .y(out[3:0])
);



  
  task initialize();
  begin
   {a,b,command}=0;
  end
   endtask

 

   task inputs(input [7:0]i);
      begin
	 a=i[3:0];
	 b=i[7:4];
      end
   endtask

   task cmd (input [3:0]l);
      begin
         command=l;
      end
   endtask

   task delay();
      begin
	 #10;
      end
   endtask
	

   always@(command)
      begin
         case (command)
	      BUFF   : string_cmd = "BUFF";
        NOR_L  : string_cmd = "NOR_L";
        NOR_B  : string_cmd = "NOR_B";
        NAND_L : string_cmd = "NAND_L";
        NAND_B : string_cmd = "NAND_B";
        OR_L   : string_cmd = "OR_L";
        OR_B   : string_cmd = "OR_B";
        AND_L  : string_cmd = "AND_L";
        AND_B  : string_cmd = "AND_B";
        default: string_cmd = "UNKNOWN";
	 endcase
      end
			
  
			
   initial
   begin
      
      initialize;
      delay;
      for ( i=0;i<4;i=m+1 ) begin
      for ( j=0;j<4;j=m+1 ) begin
      for ( k=0;k<9;k=m+1 ) begin
         l={i,j};
         inputs(l);
         m=k;
         cmd(m);
         delay;
         
      end
   end
end
end


   initial 
      $monitor("Input  a=%b, b=%b, command=%s, Output out=%b",a,b,string_cmd,out);
								
   
endmodule
