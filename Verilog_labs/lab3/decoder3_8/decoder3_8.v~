module encoder3_8 (
input [2:0]data_in,
output reg [7:0]data_out
);

always@(*)



begin
data_out[7:0]=8'b0;
case(data_in)
3'b000:data_out[0]=1'b1;
3'b001:data_out[1]=1'b1;
3'b010:data_out[2]=1'b1;
3'b011:data_out[3]=1'b1;
3'b100:data_out[4]=1'b1;
3'b101:data_out[5]=1'b1;
3'b110:data_out[6]=1'b1;
3'b111:data_out[7]=1'b1;
default:data_out=8'b0;
endcase
end
endmodule
