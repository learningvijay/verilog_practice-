
module counter_tb;

reg clk,rst,load; 
reg[3:0]data_in;
wire [3:0]count;



counter c1(
.clk(clk),
.rst(rst),
.load(load),
.data_in(data_in[3:0]),
.count(count[3:0])
);
parameter N=10;

task initialize;
begin
rst=1'b0;
load=1'b0;
data_in=4'b0000;
end
endtask

task reset;
begin
@(negedge clk)
rst=1'b1;
@(negedge clk)
rst=1'b0;
end
endtask

task loading(input [3:0]i);
begin
@(negedge clk)
load=1'b1;
data_in=i[3:0];
#10;
@(negedge clk)
load=1'b0;
end
endtask

task delay;
begin
#N;
end
endtask


initial
clk=0;
always #5 clk=~clk;

initial
begin
initilize;
delay;
reset;
delay;
delay;
delay;
loading(4'd10);
delay;
delay;
reset;
delay;
delay;
loading(4'd6);
reset;
delay;
delay;
delay;
delay;

end

initial
$monitor("input rst=%b load=%b data_in=%b output count=%b",rst,load,data_in,count);

initial
#500 $finish;

endmodule





