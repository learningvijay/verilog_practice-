
module mod_counter_loadable_tb;
parameter CYCLE=10;
parameter N=4;

reg clk,rst,load; 
reg[N-1:0]data_in;
wire [N-1:0]count;
wire data_in_invalid;




mod_counter_loadable c1(
.clk(clk),
.rst(rst),
.load(load),
.data_in(data_in[N-1:0]),
.count(count[N-1:0]),
.data_in_invalid(data_in_invalid)
);


task initialize;
begin
rst=1'b0;
load=1'b0;
data_in=4'b0000;

end
endtask

9164922175

task reset;
begin
@(negedge clk)
rst=1'b1;
@(negedge clk)
rst=1'b0;
end
endtask

task loading (input [N-1:0]i);
begin
@(negedge clk)
load=1'b1;
data_in=i[N-1:0];
#10;
@(negedge clk)
load=1'b0;
end
endtask

task delay;
begin
#10;
end
endtask


initial
clk=0;
always #(CYCLE/2) clk=~clk;

initial
begin
initialize;
delay;
reset;
delay;
delay;
delay;
loading(4'd11);
delay;
delay;
reset;
delay;
delay;
loading(4'd12);
reset;
delay;
delay;
delay;
delay;

end

initial
$monitor("input rst=%b load=%b data_in=%b output count=%b data_in_invalid =%b ",rst,load,data_in,count,data_in_invalid);

initial
#500 $finish;

endmodule





